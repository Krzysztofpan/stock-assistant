# =============================================================================
# Stock Assistant — centralna konfiguracja (katalog główny repozytorium)
# Skopiuj: cp .env.example .env
# Docker Compose ładuje ten plik automatycznie (env_file + substytucja ${VAR}).
# =============================================================================

# --- Porty serwisów (host + kontener) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000
REDIS_PORT=6379

# --- Hosty (komunikacja między serwisami) ---
# Lokalny dev: localhost | Docker: compose nadpisuje BACKEND_HOST / REDIS_HOST
BACKEND_HOST=localhost
REDIS_HOST=localhost

# --- Frontend ---
FRONTEND_URL=http://localhost:${FRONTEND_PORT}
NODE_ENV=development
# Opcjonalnie — nadpisuje BACKEND_HOST + BACKEND_PORT (np. pełny URL)
# BACKEND_URL=http://localhost:8000
# Produkcja: FRONTEND_URL=https://twoja-subdomena.duckdns.org

# --- Backend: API keys (wymagane) ---
OPENAI_API_KEY=
EODHD_API_KEY=
FINNHUB_API_KEY=

# --- LangSmith ---
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=stock-assistant
LANGSMITH_TRACKING=true

# --- Baza danych (Supabase / PostgreSQL) ---
DATABASE_URL=
DATABASE_PASSWORD=

# --- JWT ---
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600

# --- Backend: opcjonalne ---
APP_ENV=development
# Produkcja: APP_ENV=production
UVICORN_RELOAD=true
# Produkcja: UVICORN_RELOAD=false
HF_TOKEN=
LOG_LEVEL=INFO
AGENT_MODEL=gpt-4.1-mini
LLM_MODEL=gpt-4o-mini
CHEAP_LLM_MODEL=gpt-5-nano
LLM_TEMPERATURE=0
TOKENS_BETWEEN_SUMMARY=500
MESSAGES_MAX_LIMIT=30
CONVERSATIONS_MAX_LIMIT=30
CACHE_TTL_SECONDS=300
MAX_RETRIES=0
RATE_LIMIT_FOR_QUESTION=100/hour
FINNHUB_STORAGE_DIR=/tmp/finnhub_storage
ENABLE_EODHD=false
ENABLE_YFINANCE=true
ENABLE_FINNHUB=true
UVICORN_HOST=0.0.0.0
