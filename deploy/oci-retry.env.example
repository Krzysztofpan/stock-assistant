# Skopiuj: cp deploy/oci-retry.env.example deploy/oci-retry.env
# Wypełnij OCID-y z konsoli OCI (Profile → Tenancy / Compartment → Copy OCID).

COMPARTMENT_ID=ocid1.compartment.oc1..aaaa...
SUBNET_ID=ocid1.subnet.oc1.eu-frankfurt-1.aaaa...

# Ścieżka do klucza publicznego SSH (ten sam co w kreatorze VM).
SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# Opcjonalnie — zostaw puste, skrypt sam znajdzie Ubuntu 22.04 ARM.
# IMAGE_ID=

DISPLAY_NAME=stock-assistant
OCPUS=1
MEMORY_GB=6
BOOT_VOLUME_GB=50

# Co ile sekund powtarzać (domyślnie 5 min).
RETRY_INTERVAL_SEC=300

# Kolejność AD — Frankfurt ma AD-1, AD-2, AD-3.
AVAILABILITY_DOMAINS="AD-1 AD-2 AD-3"

# --- Jak znaleźć OCID-y (oci-cli skonfigurowany: oci setup config) ---
# tenancy:     oci iam compartment list --compartment-id-in-subtree true -c <TENANCY_OCID>
# subnet:      oci network subnet list -c $COMPARTMENT_ID --display-name "public subnet"
# AD (pełne):  oci iam availability-domain list -c $COMPARTMENT_ID --query 'data[*].name'
